<domain type="kvm">
  <name>windows10</name>
  <memory unit="GiB">16</memory>
  <vcpu>4</vcpu>

  <os firmware="efi">
    <type arch="x86_64" machine="pc-q35-8.2">hvm</type>
  </os>

  <features>
    <acpi/>
    <apic/>
    <!-- Hyper-V enlightenments: significantly reduce CPU overhead for Windows guests -->
    <hyperv mode="custom">
      <relaxed state="on"/>
      <vapic state="on"/>
      <spinlocks state="on" retries="8191"/>
      <vpindex state="on"/>
      <synic state="on"/>
      <stimer state="on"/>
      <reset state="on"/>
      <frequencies state="on"/>
      <tlbflush state="on"/>
      <ipi state="on"/>
    </hyperv>
    <vmport state="off"/>
  </features>

  <cpu mode="host-passthrough" check="none" migratable="on"/>

  <!-- Windows expects local time on the hardware clock, not UTC -->
  <clock offset="localtime">
    <timer name="rtc" tickpolicy="catchup"/>
    <timer name="pit" tickpolicy="delay"/>
    <timer name="hpet" present="no"/>
    <timer name="hypervclock" present="yes"/>
  </clock>

  <on_poweroff>destroy</on_poweroff>
  <on_reboot>restart</on_reboot>
  <on_crash>destroy</on_crash>

  <devices>
    <!-- Whole /dev/nvme1n1 as a raw passthrough block device -->
    <disk type="file" device="disk">
      <driver name="qemu" type="qcow2" cache="none" io="native" discard="unmap"/>
      <source file="/srv/vms/data/windows10.qcow2"/>
      <target dev="vda" bus="virtio"/>
      <boot order="1"/>
    </disk>

    <!-- Windows 10 ISO with VirtIO drivers already merged — update path before first boot -->
    <disk type="file" device="cdrom">
      <driver name="qemu" type="raw"/>
      <source file="/srv/vms/isos/en-us_windows_10_iot_enterprise_ltsc_2021_x64_dvd_257ad90f_virtio.iso"/>
      <target dev="sda" bus="sata"/>
      <readonly/>
      <boot order="2"/>
    </disk>

    <!-- NAT networking — VM gets internet; host is reachable at 192.168.122.1 -->
    <interface type="network">
    <mac address="02:00:c0:a8:7a:64"/>
      <source network="default"/>
      <model type="virtio"/>
    </interface>

    <!-- SPICE display — open with virt-manager or: remote-viewer spice://localhost:PORT -->
    <graphics type="spice" autoport="yes">
      <listen type="none"/>
      <image compression="off"/>
    </graphics>
    <video>
      <model type="qxl" ram="65536" vram="65536" vgamem="16384" heads="1" primary="yes"/>
    </video>

    <!-- 4 SPICE USB redirection slots — forward pendrives via virt-manager → Redirect USB -->
    <redirdev bus="usb" type="spicevmc"/>
    <redirdev bus="usb" type="spicevmc"/>
    <redirdev bus="usb" type="spicevmc"/>
    <redirdev bus="usb" type="spicevmc"/>

    <controller type="usb" index="0" model="qemu-xhci" ports="15"/>

    <!-- Tablet input: absolute mouse positioning, no cursor capture needed -->
    <input type="tablet" bus="usb"/>

    <sound model="ich9"/>
    <memballoon model="virtio"/>
    <rng model="virtio">
      <backend model="random">/dev/urandom</backend>
    </rng>
  </devices>
</domain>
